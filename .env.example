# Copie este ficheiro para ".env" na raiz do projeto e cole o seu token.
# GitHub → Settings → Developer settings → Fine-grained tokens →
#   Resource owner: a sua conta | Repository: OnboardingEscritaFiscal
#   Permissions → Issues: Read-only (suficiente para listar avisos e evitar limite 403)
# Depois: npm run build
VITE_GITHUB_TOKEN=
